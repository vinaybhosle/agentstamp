  "url": "https://agentstamp.org",
  "capabilities": [
    "trust_verification",
    "identity_certification",
    "agent_registry",
    "reputation_scoring",
    "eu_ai_act_compliance",
    "w3c_verifiable_credentials",
    "dns_agent_discovery",
    "forensic_audit_trail",
    "key_rotation",
