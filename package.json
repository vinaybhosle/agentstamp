{
  "name": "agentstamp",
  "version": "2.0.0",
  "description": "Stamp your agent into existence. Identity certificates, public registry, and wishing well for AI agents.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node scripts/seed-demo.js",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e --reporter=verbose",
    "test:e2e:ui": "vitest --ui tests/e2e",
    "test:e2e:public": "vitest run tests/e2e/flow14-public-endpoints.test.js --reporter=verbose",
    "test:e2e:security": "vitest run tests/e2e/flow15-security-hardening.test.js --reporter=verbose",
    "test:e2e:new": "vitest run tests/e2e/flow14-public-endpoints.test.js tests/e2e/flow15-security-hardening.test.js --reporter=verbose",
    "test:all": "vitest run --reporter=verbose",
    "db:check": "node scripts/db-quality-check.js",
    "db:check:summary": "node scripts/db-quality-check.js --summary",
    "db:fix": "node scripts/db-quality-check.js --fix --summary",
    "db:cleanup-e2e": "node scripts/cleanup-e2e.js"
  },
  "keywords": [
    "x402",
    "ai-agents",
    "identity",
    "registry",
    "micropayments",
    "base",
    "usdc"
  ],
  "author": "Vinay Bhosle",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "@x402/express": "^2.6.0",
    "@x402/fetch": "^2.6.0",
    "@x402/svm": "^2.6.0",
    "better-sqlite3": "^12.6.2",
    "bs58": "^6.0.0",
    "cors": "^2.8.0",
    "dotenv": "^16.0.0",
    "ethers": "^6.16.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "nanoid": "^3.3.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "vitest": "^4.1.0"
  }
}
